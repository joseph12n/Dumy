# Expo app environment
# For Android physical device, use your PC LAN IP instead of localhost.
EXPO_PUBLIC_AI_BACKEND_URL=http://127.0.0.1:8787

# SaaS mode for production builds: forces the app to use a public backend only.
EXPO_PUBLIC_AI_MODE=hybrid

# Example for production builds:
# EXPO_PUBLIC_AI_BACKEND_URL=https://api.your-domain.com
# EXPO_PUBLIC_AI_MODE=online

# Free personal deployment example:
# EXPO_PUBLIC_AI_BACKEND_URL=https://your-cloudflare-tunnel-url.trycloudflare.com
# EXPO_PUBLIC_AI_MODE=online
