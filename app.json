{
  "expo": {
    "name": "dumy",
    "slug": "dumy-finance",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dumy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "buildNumber": "2",
      "supportsTablet": true
    },
    "android": {
      "versionCode": 2,
      "package": "com.joseph12n.dumy",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Dumy necesita la camara para escanear recibos y facturas."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Dumy necesita acceso a tus fotos para cargar imagenes de recibos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "955c54fd-e497-4f60-8e3f-9d2050d7784b"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
